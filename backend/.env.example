# DeepSeek API密钥
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 阿里云百炼（DashScope）API密钥
# 用于校验用户上传图片是否同时包含“房子、树、人物”三要素
BAILIAN_API_KEY=your_bailian_api_key_here

# 可选：视觉模型（支持逗号分隔多模型回退）
# BAILIAN_VISION_MODEL=qwen-vl-max-latest,qwen-vl-max

# 可选：用户上传图片大小上限（MB），默认20，范围1~50
# CUSTOM_IMAGE_MAX_MB=20

# 可选：发送给百炼多模态模型的图片大小上限（MB），默认9，范围1~20
# 服务端会在超过该值时自动压缩图片再识别
# BAILIAN_IMAGE_MAX_MB=9

# 其他免费AI API选项：
# 1. DeepSeek (推荐): https://platform.deepseek.com/
# 2. 阿里云通义千问: https://dashscope.aliyun.com/
# 3. 智谱AI (ChatGLM): https://open.bigmodel.cn/
# 4. 百度文心一言: https://cloud.baidu.com/product/wenxinworkshop
